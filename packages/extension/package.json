{
  "name": "portdrop",
  "displayName": "PortDrop",
  "description": "Share your running local app via a QR code. You control the window. You control the clock.",
  "version": "0.1.0",
  "publisher": "codebreeder",
  "author": {
    "name": "Frandy Slueue",
    "alias": "CodeBreeder",
    "email": "frandyslueue@gmail.com",
    "url": "https://frandycode.dev"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/frandycode/codebreeder-dev/portdrop"
  },
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "tunnel",
    "qr code",
    "share",
    "localhost",
    "preview",
    "ngrok",
    "cloudflare"
  ],
  "icon": "assets/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "portdrop.start",
        "title": "PortDrop: Start Session",
        "icon": "$(broadcast)"
      },
      {
        "command": "portdrop.stop",
        "title": "PortDrop: Stop Session",
        "icon": "$(debug-stop)"
      },
      {
        "command": "portdrop.openDashboard",
        "title": "PortDrop: Open Dashboard",
        "icon": "$(link-external)"
      },
      {
        "command": "portdrop.copyUrl",
        "title": "PortDrop: Copy Session URL",
        "icon": "$(copy)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "portdrop-sidebar",
          "title": "PortDrop",
          "icon": "assets/activity-icon.svg"
        }
      ]
    },
    "views": {
      "portdrop-sidebar": [
        {
          "id": "portdrop.sessionView",
          "name": "Session",
          "type": "webview",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "portdrop.start"
        },
        {
          "command": "portdrop.stop"
        },
        {
          "command": "portdrop.openDashboard"
        },
        {
          "command": "portdrop.copyUrl"
        }
      ]
    },
    "configuration": {
      "title": "PortDrop",
      "properties": {
        "portdrop.defaultTTL": {
          "type": "string",
          "default": "1h",
          "enum": [
            "15m",
            "1h",
            "4h"
          ],
          "description": "Default session time-to-live."
        },
        "portdrop.autoDetectPort": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect running dev server ports on startup."
        },
        "portdrop.showBadge": {
          "type": "boolean",
          "default": true,
          "description": "Inject the PortDrop badge into the viewer's app preview."
        },
        "portdrop.blocklist": {
          "type": "array",
          "default": [],
          "description": "Additional file paths or patterns to exclude from Code View.",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --watch",
    "package": "bash ../../scripts/package-extension.sh",
    "lint": "eslint src --ext ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.89.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/vsce": "^2.26.0",
    "esbuild": "^0.28.0",
    "qrcode": "^1.5.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.4.0"
  }
}
