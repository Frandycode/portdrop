# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
out/
.next/
*.vsix
*.tsbuildinfo

# Environment
.env
.env.*
!.env.example

# Secrets / certs — never committed
*.key
*.pem
*.secret
credentials.*

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# VS Code (project-specific kept, user-specific ignored)
.vscode/settings.json
.vscode/launch.json
!.vscode/extensions.json

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# Docker
*.override.yml

# Turbo
.turbo/

# Testing
coverage/
.nyc_output/
